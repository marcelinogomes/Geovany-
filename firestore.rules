rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == '5bRjaeshc0TIdOB4BqCjSjSPlLv2' ||
        request.auth.uid == 'ddE2CUo6j2b1bE7Tey0qgyQTgpD2' ||
        (request.auth.token.get('email', '') == 'geovanymarcelino25@gmail.com' || 
         request.auth.token.get('email', '') == 'mginformatica78@gmail.com')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Validation helper for user profile
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'student'];
    }

    // --- Users ---
    match /users/{userId} {
      // Users can always read their own profile. Admins can read all.
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      // Creation: must match auth UID
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      
      // Update: owner can update profile (but not role!), admin can update everything
      allow update: if isAdmin() || (
        isOwner(userId) && 
        isValidUser(request.resource.data) &&
        request.resource.data.role == resource.data.role
      );
      
      allow delete: if isAdmin();
    }

    // --- Training Data (Workouts) ---
    match /workouts/{workoutId} {
      allow get: if isSignedIn() && (isAdmin() || resource.data.studentId == request.auth.uid);
      allow list: if isSignedIn() && (isAdmin() || (request.query.limit <= 50 && resource.data.studentId == request.auth.uid));
      allow create, update, delete: if isAdmin();
    }

    // --- Exercises ---
    match /exercises/{exerciseId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Progress ---
    match /progress/{entryId} {
      allow get: if isSignedIn() && (isAdmin() || resource.data.studentId == request.auth.uid);
      allow list: if isSignedIn() && (isAdmin() || resource.data.studentId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // --- CMS / Site Content ---
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /plans/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /results/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
