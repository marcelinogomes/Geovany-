rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == '5bRjaeshc0TIdOB4BqCjSjSPlLv2' ||
        request.auth.uid == 'ddE2CUo6j2b1bE7Tey0qgyQTgpD2' ||
        request.auth.token.email == 'geovanymarcelino25@gmail.com' ||
        request.auth.token.email == 'mginformatica78@gmail.com'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Users ---
    // Allow users to read and create their own profile always
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    // --- Workouts ---
    match /workouts/{workoutId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.studentId == request.auth.uid);
      allow write: if isAdmin();
    }

    // --- Exercises ---
    match /exercises/{exerciseId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Progress ---
    match /progress/{entryId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.studentId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // --- Settings / CMS ---
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /plans/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /results/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Default Deny (At the end) ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
