rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == '5bRjaeshc0TIdOB4BqCjSjSPlLv2' ||
        request.auth.uid == 'ddE2CUo6j2b1bE7Tey0qgyQTgpD2' ||
        (request.auth.token.email != null && 
         (request.auth.token.email.lower() == 'geovanymarcelino25@gmail.com' || 
          request.auth.token.email.lower() == 'mginformatica78@gmail.com'))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collections ---

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /workouts/{workoutId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.studentId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /exercises/{exerciseId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /progress/{entryId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.studentId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /plans/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /results/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
